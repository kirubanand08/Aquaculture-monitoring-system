#include <OneWire.h>
#include <DallasTemperature.h>

//PIN DEFINITIONS
#define PH_PIN 35
#define TURBIDITY_PIN 34
#define ONE_WIRE_BUS 4

OneWire oneWire(ONE_WIRE_BUS);
DallasTemperature sensors(&oneWire);

float voltagePH, phValue;
float turbVoltage, turbidityNTU;
float temperatureC;

// CALIBRATION
float calibration_value = 21.34;


// Averaging function for stable ADC
int readADC(int pin) {
  int sum = 0;
  for (int i = 0; i < 10; i++) {
    sum += analogRead(pin);
    delay(10);
  }
  return sum / 10;
}

void setup() {
  Serial.begin(115200);
  sensors.begin();

  Serial.println("Water Quality Monitoring Started...");
}

void loop() {

  // ================= TEMPERATURE =================
  sensors.requestTemperatures();
  temperatureC = sensors.getTempCByIndex(0);

  // ================= pH SENSOR =================
  int phADC = readADC(PH_PIN);
  voltagePH = phADC * (3.3 / 4095.0);

  // Calibrated pH formula
  phValue = -5.70 * voltagePH + calibration_value;

  // ================= TURBIDITY =================
  int turbADC = readADC(TURBIDITY_PIN);
  turbVoltage = turbADC * (3.3 / 4095.0);

  if (turbVoltage < 2.5) {
    turbidityNTU = -1120.4 * sq(turbVoltage) + 5742.3 * turbVoltage - 4352.9;
  } else {
    turbidityNTU = 0;
  }

  //Result Part
  Serial.println("-------- Water Quality --------");

  Serial.print("Temperature: ");
  Serial.print(temperatureC);
  Serial.println(" °C");

  Serial.print("pH Value: ");
  Serial.println(phValue);

  Serial.print("Turbidity: ");
  Serial.print(turbidityNTU);
  Serial.println(" NTU");

  Serial.println("-------------------------------");

  delay(2000);
}
